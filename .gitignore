# =============================================================================
# Neuro — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Turborepo
# -----------------------------------------------------------------------------
.turbo/

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
!.env.example

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
.venv/
venv/
env/
*.whl
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
.coverage.*

# -----------------------------------------------------------------------------
# Electron
# -----------------------------------------------------------------------------
release/
*.dmg
*.AppImage
*.snap
*.deb
*.rpm
*.exe
*.msi
*.nupkg

# -----------------------------------------------------------------------------
# Databases (local dev)
# -----------------------------------------------------------------------------
*.db
*.db-journal
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# IDE & Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# OS Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
*.lcov

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.tgz
.cache/
.parcel-cache/
.next/
