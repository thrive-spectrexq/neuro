# =============================================================================
# Neuro — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All AI provider keys are optional — Neuro works fully offline.
# =============================================================================

# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
NEURO_ENV=development
NEURO_SECRET_KEY=your-secret-key-here

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite (default — no setup required)
DATABASE_URL=sqlite+aiosqlite:///./neuro.db
# PostgreSQL (uncomment to use)
# DATABASE_URL=postgresql://user:pass@localhost:5432/neuro

# -----------------------------------------------------------------------------
# Redis (task queue & cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Vector Database (ChromaDB)
# -----------------------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001

# -----------------------------------------------------------------------------
# AI Providers (all optional)
# -----------------------------------------------------------------------------
# Local AI via Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Cloud AI — set your API key to enable
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Embedding Model
# -----------------------------------------------------------------------------
# HuggingFace Model for SentenceTransformers (default: all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Cloud: text-embedding-3-small (via OpenAI, uncomment to use)
# EMBEDDING_MODEL=text-embedding-3-small
